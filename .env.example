# Genius365 Design Factory — environment template.
# Copy this to ~/.hermes/.env (global, all profiles) and paste the real values.
# These keys are shared out-of-band via the team password manager. NEVER commit real keys.

# Required — model access for every profile (OpenRouter).
OPENROUTER_API_KEY=

# Optional — only the image-asset-lab profile (free image-generation lane).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional — alternate provider, if used.
NVIDIA_API_KEY=
